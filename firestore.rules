rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── USERS ──
    match /users/{userId} {
      allow read, write: if request.auth != null
        && request.auth.uid == userId;
    }

    // ── ENROLLMENTS ──
    match /enrollments/{enrollId} {

      // Student can CREATE their own enrollment
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'pending';

      // Student can READ their own enrollments
      allow read: if request.auth != null
        && resource.data.userId == request.auth.uid;

      // Admin can READ and UPDATE any enrollment
      allow read, update: if request.auth != null
        && request.auth.token.email in ['99naveenrai@gmail.com'];
    }

    // ── CONTENT (Class → Subject → Chapter → Topic → Video/Playlist) ──
    match /content/{contentId} {
      // Everyone (even logged-out visitors) can READ content listings
      allow read: if true;

      // Only admin can CREATE, UPDATE, DELETE content
      allow create, update, delete: if request.auth != null
        && request.auth.token.email in ['99naveenrai@gmail.com'];
    }

    // ── PROGRESS (Continue Learning tracking) ──
    match /progress/{userId} {
      allow read, write: if request.auth != null
        && request.auth.uid == userId;
    }

    // ── LEGACY: courses (old structure, kept for migration read) ──
    match /courses/{courseId} {
      allow read: if request.auth != null
        && request.auth.token.email in ['99naveenrai@gmail.com'];
      allow write: if request.auth != null
        && request.auth.token.email in ['99naveenrai@gmail.com'];
    }

  }
}
